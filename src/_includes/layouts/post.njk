---
layout: layouts/base.njk
wideLayout: true
---
{% set fullUrl = metadata.siteUrl + (page.url | replace('index.html', '')) %}
{% set rt = (content | readingTimeMinutes) %}

<script type="application/ld+json">{{ ({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": page.date | dateIso,
  "dateModified": page.date | dateIso,
  "author": { "@type": "Organization", "name": "Offcourse" },
  "publisher": { "@type": "Organization", "name": "Offcourse" },
  "mainEntityOfPage": { "@type": "WebPage", "@id": fullUrl }
}) | jsonScript | safe }}</script>

{% if faq and faq.length %}
<script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{% for item in faq %}{"@type":"Question","name":{{ item.q | dump }},"acceptedAnswer":{"@type":"Answer","text":{{ item.a | dump }}}}{% if not loop.last %},{% endif %}{% endfor %}]}</script>
{% endif %}

<article>
  <p class="page-eyebrow"><a href="/blog/" style="color:inherit;text-decoration:none;">Blog</a></p>
  <h1 class="page-title">{{ title }}</h1>
  <p class="blog-card-meta">{{ page.date | postDate }} · about {{ rt }} min read</p>
  <p class="post-summary">{{ summary }}</p>
  <div class="post-content">{{ content | safe }}</div>

  {% if faq and faq.length %}
  <section class="post-faq" aria-labelledby="faq-heading">
    <h2 id="faq-heading">FAQ</h2>
    {% for item in faq %}
    <div class="faq-item">
      <strong>{{ item.q }}</strong>
      <p>{{ item.a }}</p>
    </div>
    {% endfor %}
  </section>
  {% endif %}
</article>
